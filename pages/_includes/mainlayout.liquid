---
title: Trans Composers Project
description: The Trans Composers Project (TCP) seeks to celebrate trangender composers by providing them opportunities to connect, share, learn, and grow with other queer and allied musicians.
---
<!doctype html>
<html lang="en">
    <head>
        <!-- General metadata -->
        <title>{{ title }}</title>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="{{ description }}">
        <link rel="canonical" href="https://transcomposersproject.com{{ page.url }}">

        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/media/favicon/favicon-96x96.png" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="/media/favicon/favicon.svg">
        <link rel="shortcut icon" href="/media/favicon/favicon.ico">
        <link rel="apple-touch-icon" sizes="180x180" href="/media/favicon/apple-touch-icon.png">
        <meta name="apple-mobile-web-app-title" content="Trans Composers Project">
        <link rel="manifest" href="/media/favicon/site.webmanifest">

        <!-- OG, social meta properties -->
        <meta property="og:url" content="https://transcomposersproject.com{{ page.url }}">
        <meta property="og:type" content="website">
        <meta property="og:title" content="{{ title }}">
        <meta property="og:description" content="{{ description }}">
        {%- if og_image %}
            <meta property="og:image" content="https://transcomposersproject.com{{ og_image }}">
            {%- if og_image_width %}
                <meta property="og:image:width" content="{{ og_image_width }}">
            {%- endif %}
            {%- if og_image_height %}
                <meta property="og:image:height" content="{{ og_image_height }}">
            {%- endif %}
            {%- if og_image_alt %}
                <meta property="og:image:alt" content="{{ og_image_alt }}">
            {%- endif %}
        {%- else %}
            <meta property="og:image" content="https://transcomposersproject.com/media/og_image.jpg">
            <meta property="og:image:type" content="image/jpeg">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
            <meta
                property="og:image:alt"
                content=""
            >
        {%- endif %}

        <!-- My styles -->
        <link rel="stylesheet" type="text/css" href="/styles/global.css">
        <script defer type="text/javascript" src="/scripts/global.js"></script>

        <!-- rel="me" verification -->
        <link rel="me" href="https://github.com/trans-composers-project">
    </head>
    <body>
        <a class="skip-link" href="#content">Skip to content</a>
        <!-- includes footer - makes it fill the page -->
        <div class="wrapper">
            <!-- navigation menu -->
            <header>
				<div id="header-row">
					<h1 id="banner-heading"><a href="/">Trans Composers Project</a></h1>
					<button id="hamburger">
						<img src="/media/ui/hamburger-menu.svg" alt="3-line dropdown menu icon" width="28" height="28">
					</button>
				</div>
                <nav id="main-menu">
					<a class="menu-item" href="/">Home</a>
					<a class="menu-item" href="/about">About</a>
					<a class="menu-item" href="/upcoming">Upcoming</a>
				</nav>
				<div class="gradient-line"></div>
            </header>

            <main role="main" id="content">
                {{ content }}
            </main>

            <!-- footer -->
            <footer>
				<div class="gradient-line"></div>
				<div id="social-icons">
					<a href="https://bsky.app/profile/transcomposersproj.bsky.social" title="Bluesky">
						<img src="/media/social/bluesky-logo-dark.svg" alt="Dark monochrome Bluesky logo" width="36" height="32">
					</a>
					<a href="https://www.facebook.com/profile.php?id=61591029684714" title="Facebook">
						<img src="/media/social/facebook-logo-dark.svg" alt="Dark monochrome Facebook logo" width="32" height="32">
					</a>
					<a href="https://www.instagram.com/trans.composers.project/" title="Instagram">
						<img src="/media/social/instagram-logo-dark.svg" alt="Dark monochrome Instagram logo" width="32" height="32">
					</a>
					<a href="https://mastodon.social/@transcomposersproject" title="Mastodon">
						<img src="/media/social/mastodon-logo-dark.svg" alt="Dark monochrome Mastodon logo" width="32" height="34">
					</a>
					{%- comment %}<a href="https://x.com/transcomposers" title="Twitter">
						<img src="/media/social/twitter-logo-dark.svg" alt="Dark monochrome Twitter logo" width="32" height="32">
					</a>{% endcomment -%}
					<a href="https://www.youtube.com/@TheTransComposersProject" title="YouTube">
						<img src="/media/social/youtube-logo-dark.svg" alt="Dark monochrome YouTube logo" width="32" height="32">
					</a>
				</div>
				<p>Site design &copy; Reilly Spitzfaden, {{ 'now' | date: '%Y' }}</p>
            </footer>
            <!-- close "wrapper" -->
        </div>
    </body>
</html>
